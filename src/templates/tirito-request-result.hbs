<!doctype html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Solicitud procesada</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
            background: #f5f7fb;
            color: #333;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 28px auto;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
        }

        .header {
            background: linear-gradient(90deg, #6a5af9, #8e44fd);
            color: #fff;
            padding: 24px;
            text-align: center;
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            margin: 0;
        }

        .content {
            padding: 24px;
            color: #333;
        }

        .result-accepted {
            background: #d1fae5;
            border-left: 4px solid #10b981;
            padding: 12px 16px;
            border-radius: 4px;
            margin: 16px 0;
        }

        .result-rejected {
            background: #fee2e2;
            border-left: 4px solid #ef4444;
            padding: 12px 16px;
            border-radius: 4px;
            margin: 16px 0;
        }

        .btn {
            display: inline-block;
            padding: 12px 20px;
            background: #6a5af9;
            color: #fff;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
        }

        .muted {
            color: #6b7280;
            font-size: 14px;
        }

        .footer {
            padding: 16px;
            text-align: center;
            font-size: 13px;
            color: #9ca3af;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <div class="logo">Tirito</div>
        </div>
        <div class="content">
            <h3 style="margin-top:0">Hola {{firstName}},</h3>

            {{#if accepted}}
            <div class="result-accepted">
                <p style="margin:0"><strong>Tu solicitud para "{{tiritoTitle}}" fue aceptada.</strong></p>
                <p style="margin:4px 0 0 0">Ya podes iniciar el chat con el creador del tirito.</p>
            </div>
            {{else}}
            <div class="result-rejected">
                <p style="margin:0"><strong>Tu solicitud para "{{tiritoTitle}}" fue rechazada.</strong></p>
                <p style="margin:4px 0 0 0">No te desanimes, hay muchos tiritos disponibles.</p>
            </div>
            {{/if}}

            <p style="text-align:center; margin:18px 0">
                <a class="btn" href="{{actionUrl}}">{{buttonText}}</a>
            </p>
        </div>
        <div class="footer">Saludos — El equipo de Tirito</div>
    </div>
</body>

</html>