<!doctype html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Nueva calificacion</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
            background: #f5f7fb;
            color: #333;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 28px auto;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
        }

        .header {
            background: linear-gradient(90deg, #6a5af9, #8e44fd);
            color: #fff;
            padding: 24px;
            text-align: center;
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            margin: 0;
        }

        .content {
            padding: 24px;
            color: #333;
        }

        .stars {
            font-size: 28px;
            text-align: center;
            margin: 16px 0;
            letter-spacing: 4px;
        }

        .comment-box {
            background: #f8f9ff;
            border: 1px solid #e8e8f0;
            border-radius: 8px;
            padding: 12px 16px;
            margin: 12px 0;
            font-style: italic;
            color: #555;
        }

        .btn {
            display: inline-block;
            padding: 12px 20px;
            background: #6a5af9;
            color: #fff;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
        }

        .muted {
            color: #6b7280;
            font-size: 14px;
        }

        .footer {
            padding: 16px;
            text-align: center;
            font-size: 13px;
            color: #9ca3af;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <div class="logo">Tirito</div>
        </div>
        <div class="content">
            <h3 style="margin-top:0">Hola {{firstName}},</h3>
            <p><strong>{{raterName}}</strong> te califico por el tirito <strong>"{{tiritoTitle}}"</strong>:</p>

            <div class="stars">{{starsDisplay}}</div>
            <p style="text-align:center; font-size:16px; font-weight:600;">{{score}} de 5</p>

            {{#if comment}}
            <div class="comment-box">
                "{{comment}}"
            </div>
            {{/if}}

            <p style="text-align:center; margin:18px 0">
                <a class="btn" href="{{profileUrl}}">Ver mi perfil</a>
            </p>
        </div>
        <div class="footer">Saludos — El equipo de Tirito</div>
    </div>
</body>

</html>